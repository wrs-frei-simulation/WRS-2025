  - <<: *bent1
    type: SubBody
    prefix: SB8_
    translation: [ 0.4, -0.25, 0.5 ]
  - <<: *bent1
    type: SubBody
    prefix: SB9_
    translation: [ 0.4, 0.25, 0.5 ]