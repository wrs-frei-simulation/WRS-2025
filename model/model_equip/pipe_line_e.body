    translation: [ 0.2, -0.25, 0.5 ]
  - <<: *straight1
    prefix: SB3_
    translation: [ 0.2, 0.25, 0.5 ]
  - &straight2
    type: SubBody
    uri: "subbody/pipe_40cm.body"
    parent: Root
    prefix: SB4_
    translation: [ 0.5, 0, 0.2 ]
    rotation: [ 0, 1, 0, -90 ]
    joint_type: fixed
  - <<: *straight2
    prefix: SB5_
    translation: [ 0.5, -0.25, 0.2 ]
  - <<: *straight2
    prefix: SB6_
    translation: [ 0.5, 0.25, 0.2 ]
  - &bent1
    type: SubBody
    uri: "subbody/bent_pipe_90deg.body"
    parent: Root
    prefix: SB7_
    translation: [ 0.4, 0, 0.5 ]
    rotation: [ 1, 0, 0, 90 ]
